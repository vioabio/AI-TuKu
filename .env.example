# ============================================================
# AI-TuKu Docker 环境变量模板
# 复制此文件为 .env 并填写真实值
#   cp .env.example .env
# ============================================================

# MySQL 配置
MYSQL_ROOT_PASSWORD=root123
MYSQL_PORT=3306

# Redis 配置
REDIS_PORT=6379

# 后端服务端口
BACKEND_PORT=8123

# 前端服务端口
FRONTEND_PORT=80

# 腾讯云 COS 对象存储（生产环境必填）
COS_CLIENT_HOST=https://your-bucket.cos.ap-shanghai.myqcloud.com
COS_SECRET_ID=your-cos-secret-id
COS_SECRET_KEY=your-cos-secret-key
COS_REGION=ap-shanghai
COS_BUCKET=your-bucket-name

# 阿里云 AI API Key（使用 AI 功能时必填）
ALIYUN_AI_API_KEY=your-api-key
